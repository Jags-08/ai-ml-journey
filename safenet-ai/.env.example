# ═══════════════════════════════════════════════════════════════
#  SafeNet AI v4 — Environment Configuration
#  Copy to .env and fill in your values.
#  Lines starting with # are comments — do not need to be changed.
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
PORT=5000
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-string

# ── LLM Mode ─────────────────────────────────────────────────
# auto     = tries LM Studio → Ollama → OpenAI → Claude → rule-based
# lmstudio = use ONLY your local LM Studio 20B model
# ollama   = use ONLY Ollama
# openai   = use ONLY OpenAI GPT
# claude   = use ONLY Claude API
LLM_MODE=auto
LLM_TIMEOUT=45

# ── LM Studio (YOUR LOCAL 20B MODEL) ─────────────────────────
# Steps:
#   1. Download LM Studio from https://lmstudio.ai
#   2. Load your OSS 20B GGUF model in LM Studio
#   3. Click "Local Server" tab in LM Studio
#   4. Click "Start Server" (default port 1234)
#   5. SafeNet will auto-detect your loaded model
#
# To use a specific model name, set LM_STUDIO_MODEL explicitly.
# "auto" means SafeNet reads whatever model is currently loaded.
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=auto

# ── Ollama (local fallback) ───────────────────────────────────
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull:    ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── OpenAI GPT (cloud) ───────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
# Models:  gpt-4o, gpt-4-turbo, gpt-4o-mini, gpt-3.5-turbo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Claude API (cloud fallback) ──────────────────────────────
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Twilio SMS ────────────────────────────────────────────────
# Get credentials: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
SMS_RECIPIENT=+91XXXXXXXXXX

# ── Twilio Voice Call ─────────────────────────────────────────
CALL_RECIPIENT=+91XXXXXXXXXX
CALL_THRESHOLD=CRITICAL

# ── SendGrid Email ────────────────────────────────────────────
# Get key: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
EMAIL_FROM=safenet@yourdomain.com
EMAIL_TO=security@company.com
EMAIL_FREQ=instant

# ── Webhook / SIEM ────────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_TOKEN=
WEBHOOK_FORMAT=json

# ── Threat Intelligence ───────────────────────────────────────
# AbuseIPDB (free tier): https://www.abuseipdb.com/register
ABUSEIPDB_KEY=
VIRUSTOTAL_KEY=

# ── Simulation / Detection ────────────────────────────────────
LOG_RATE_MS=250
ATTACK_RATE=0.11
CACHE_LIMIT=1000
DEFAULT_THRESHOLD=HIGH
